# ══════════════════════════════════════
# Video Studio — Configuration
# Copy this file to .env and fill in your values
# ══════════════════════════════════════

# ── API Keys ──

# Google Gemini API (titles, thumbnails, Gemini transcription)
GOOGLE_GEMINI_API_KEY=

# YouTube API Credentials (for upload feature)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Auphonic API Key (optional, for professional audio cleanup)
AUPHONIC_API_KEY=

# ── Whisper Settings ──

WHISPER_MODEL=base
# Options: tiny (39MB), base (74MB), small (244MB), medium (769MB), large (1.5GB)
# Models are downloaded automatically on first use to ~/.cache/whisper/

WHISPER_DEVICE=cpu
# Options: cpu, cuda

# ── Paths ──
# Relative paths are resolved from project root. Absolute paths also work.

OUTPUT_DIR=output
# Where all generated files go (videos, audio, transcripts, thumbnails)

# Custom FFmpeg/FFprobe binary path (leave empty to use system PATH)
FFMPEG_PATH=
FFPROBE_PATH=

# ── Gemini Model (optional) ──

# Override default Gemini model for image generation
# GEMINI_MODEL=gemini-2.0-flash-exp

# Custom API proxy/endpoint
# GOOGLE_GEMINI_BASE_URL=
